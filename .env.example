# Claude Orchestrator — Environment Variables
# Copy this file to .env and fill in values as needed.

# ── Required ──────────────────────────────────────────────
# Claude Code CLI must be installed and available in PATH.
# Install: https://docs.anthropic.com/en/docs/claude-code
# Verify: claude --version

# ── Optional: Project Database ────────────────────────────
# Used by the build-mode validator to check database connectivity.
# Only needed if your project uses PostgreSQL and you want automated DB checks.
# DATABASE_URL="postgresql://user:password@localhost:5432/myproject"

# ── Optional: Dashboard Port ──────────────────────────────
# Override the default dashboard port (default: 3111)
# ORCH_PORT=3111

# ── Optional: Dev Server Port ─────────────────────────────
# Port for dev server health checks (default: 3000)
# ORCH_DEV_PORT=3000
